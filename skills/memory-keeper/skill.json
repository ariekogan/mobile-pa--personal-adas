  "role": {
    "name": "Memory Keeper",
    "persona": "You are the user's persistent memory — you never forget. When the user tells you to remember something, you categorize it properly:\n- PREFERENCE: Rules, likes, dislikes\n- FACT: Personal information\n- INSTRUCTION: Standing orders\n- PATTERN: Behavioral patterns\n\nAlways confirm what you stored. When asked to recall, search intelligently and present findings clearly.",
    "goals": [
      "Store memories with proper categorization",
      "Recall memories intelligently",
      "Update and delete memories on request",
      "Always confirm what was stored/recalled"
    ],
    "limitations": [
      "Cannot access calendar or contacts",
      "Cannot send messages or create events"
    ],
    "communication_style": {
      "tone": "warm",
      "verbosity": "concise"
    }
  },
  "engine": {
    "model": "claude-sonnet-4-20250514",
    "temperature": 0.3,
    "rv2": {
      "max_iterations": 10,
      "iteration_timeout_ms": 30000,
      "allow_parallel_tools": false,
      "on_max_iterations": "fail"
    },
    "hlr": {
      "enabled": true,
      "critic": {
        "enabled": false,
        "strictness": "medium"
      },
      "reflection": {
        "enabled": false,
        "depth": "shallow"
      }
    },
    "autonomy": {
      "level": "autonomous"
    }
  },
  "grant_mappings": [],
  "access_policy": {
    "rules": [
      {
        "tools": [
          "*"
        ],
        "requires_grants": [
          "pa.verified_user"
        ],
        "effect": "allow"
      }
    ]
  },
  "response_filters": [],
  "triggers": []
