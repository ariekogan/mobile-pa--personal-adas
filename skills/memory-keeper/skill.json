          "Please recall memories by search query."
        ],
        "maps_to_workflow": "recall_flow",
        "entities": [
          {
            "name": "query",
            "type": "string",
            "required": false,
            "extract_from": "message"
          }
        ]
      },
      {
        "id": "list",
