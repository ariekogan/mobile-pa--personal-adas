          "type": "string",
          "required": true,
          "description": "Search query"
        },
        {
          "name": "type",
          "type": "string",
          "required": false,
          "description": "Filter by type"
        },
        {
          "name": "limit",
          "type": "number",
          "required": false,
          "description": "Max results"
        }
      ],
      "output": {
        "type": "object",
