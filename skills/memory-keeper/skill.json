{
  "id": "memory-keeper",
  "name": "Memory Keeper",
  "description": "Personal assistants forget everything between conversations. Users need persistent memory.",
  "version": "1.0.0",
  "phase": "DEPLOYED",
  "ui_capable": false,
  "connectors": [
    "memory-mcp"
  ],
  "problem": {
    "statement": "Personal assistants forget everything between conversations. Users need persistent memory.",
    "context": "Persistent memory worker skill that stores and recalls user preferences, personal facts, standing instructions, and learned patterns.",
    "goals": [
      "Store preferences permanently",
      "Remember facts",
      "Honor standing instructions",
      "Recall relevant memories"
    ]
  },
  "tools": [
    {
      "id": "tool-mem-store",
      "id_status": "permanent",
      "name": "memory.store",
      "description": "Store a new memory.",
      "inputs": [
        {
          "name": "type",
          "type": "string",
          "required": true,
          "description": "Memory type: preference, fact, instruction, or pattern"
        },
        {
          "name": "content",
          "type": "string",
          "required": true,
          "description": "The memory content"
        },
        {
          "name": "tags",
          "type": "array",
          "required": false,
          "description": "Tags for categorization"
        },
        {
          "name": "context",
          "type": "string",
          "required": false,
          "description": "Context about when/why stored"
        }
      ],
      "output": {
        "type": "object",
        "description": "Stored memory confirmation with ID"
      },
      "source": {
        "type": "mcp_bridge",
        "connection_id": "memory-mcp",
        "mcp_tool": "memory.store"
      },
      "policy": {
        "allowed": "always"
      },
      "mock": {
        "enabled": true,
        "mode": "examples",
        "examples": [
          {
            "id": "tool-memory-store-auto",
            "input": {
              "type": "standard",
              "content": "example"
            },
            "output": {
              "success": true,
              "data": {}
            },
            "description": "Auto-generated example for memory.store"
          }
        ]
      },
      "security": {
        "classification": "public"
      }
    },
    {
