    "thresholds": {
      "accept": 0.85,
      "clarify": 0.6,
      "reject": 0.4
    },
    "out_of_domain": {
      "action": "redirect",
      "message": "This request is outside my capabilities.",
      "suggest_domains": []
    }
  },
