  "intents": {
    "supported": [
      {
        "id": "store",
        "description": "Store a new memory.",
        "examples": [
          "Store a new memory.",
          "I need to store a new memory.",
          "Can you store a new memory.?",
          "Please store a new memory."
        ],
        "maps_to_workflow": "store_flow",
        "entities": [
          {
            "name": "type",
            "type": "string",
            "required": false,
            "extract_from": "message"
          },
          {
            "name": "content",
            "type": "string",
            "required": false,
            "extract_from": "message"
          }
        ]
      },
