{
  "id": "pa-orchestrator",
  "name": "PA Orchestrator",
  "description": "A personal assistant needs a situation-aware brain that detects what's happening, decides how to respond, and routes to the right specialist — not just a static gateway that pattern-matches keywords.",
  "version": "2.3.0",
  "phase": "DEPLOYED",
  "ui_capable": false,
  "connectors": [
    "mobile-device-mcp",
    "email-mcp",
    "whatsapp-mcp",
    "memory-mcp",
    "handoff-controller-mcp"
  ],
  "problem": {
    "statement": "A personal assistant needs a situation-aware brain that detects what's happening, decides how to respond, and routes to the right specialist — not just a static gateway that pattern-matches keywords.",
    "context": "Orchestrator for a mobile personal assistant. Fuses signals (calendar, location, weather, time) into situations, checks taught rules, and routes to self-sufficient worker skills. Also handles simple requests directly without handoff.",
    "goals": [
      "Detect situations by fusing calendar + location + weather + time signals",
      "Route to the right worker skill based on situation type and user intent",
      "Handle simple queries directly (weather, time, basic calendar questions)",
      "Check taught rules before routing — follow user-taught behaviors",
      "Store detected situations as ephemeral context for workers to read",
      "Run proactively on PT5M trigger to detect situations like running late or meeting starting"
    ]
  },
