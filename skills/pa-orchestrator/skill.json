  "intents": {
    "supported": [
      {
        "id": "intent-calendar-view",
        "name": "View Calendar Events",
        "description": "User wants to see what's on their calendar",
        "patterns": [
          "what's on my calendar",
          "what on my calendar",
          "show my calendar",
          "show me my events",
          "do i have anything",
          "what do i have",
          "my schedule",
          "what's my schedule",
          "upcoming events",
          "any meetings"
        ],
        "action": "call_tool",
        "tool_sequence": [
          {
            "tool": "device.calendar.today",
            "description": "Get today's events first"
          }
        ],
        "response_template": "I found {count} events on your calendar today:\n{events_list}"
      },
      {
        "id": "intent-calendar-create",
        "name": "Create/Schedule Event",
        "description": "User wants to create, schedule, or book an event",
        "patterns": [
          "schedule",
          "book",
          "create an event",
          "add to calendar",
          "set up a meeting"
        ],
        "action": "handoff",
        "target_skill": "life-manager",
        "context": "User wants to create or modify a calendar event"
      },
      {
        "id": "intent-teach",
        "name": "Create/Modify Rule",
        "description": "User wants to teach the PA a behavior or rule",
        "patterns": [
          "when",
          "do",
          "always",
          "never",
          "teach",
          "create a rule",
          "show my rules"
        ],
        "action": "handoff",
        "target_skill": "teach-this",
        "context": "User wants to create, modify, or view automation rules"
      },
      {
        "id": "intent-message",
        "name": "Send Message",
        "description": "User wants to send a message, text, email, or WhatsApp",
        "patterns": [
          "tell",
          "text",
          "message",
          "send",
          "email",
          "whatsapp",
          "reply"
        ],
        "action": "handoff",
        "target_skill": "messaging-agent",
        "context": "User wants to send a message"
      },
      {
        "id": "intent-briefing",
        "name": "Daily Briefing",
        "description": "User wants a daily briefing or schedule analysis",
        "patterns": [
          "morning briefing",
          "how is my day",
          "what should i know",
          "daily summary",
          "day summary"
        ],
        "action": "handoff",
        "target_skill": "daily-intel",
        "context": "User wants a daily briefing"
      },
      {
        "id": "intent-notifications",
        "name": "Check Notifications",
        "description": "User wants to check or manage notifications",
        "patterns": [
          "check notifications",
          "what did i miss",
          "any important messages",
          "turn on dnd",
          "do not disturb"
        ],
        "action": "handoff",
        "target_skill": "notification-triage",
        "context": "User wants to check or manage notifications"
      }
    ],
