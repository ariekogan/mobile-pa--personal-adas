{
  "id": "life-manager",
  "name": "Life Manager",
  "description": "Busy professionals need a personal assistant that understands their schedule, relationships, and daily routines — and remembers their preferences across conversations.",
  "version": "1.0.0",
  "phase": "DEPLOYED",
  "ui_capable": false,
  "connectors": [
    "mobile-device-mcp",
    "memory-mcp"
  ],
  "problem": {
    "statement": "Busy professionals need a personal assistant that understands their schedule, relationships, and daily routines — and remembers their preferences across conversations.",
    "context": "Voice-first personal assistant managing calendar, contacts, messaging, memory, and proactive daily intelligence for a single user.",
    "goals": [
      "Give smart daily briefings when asked 'How is my day?'",
      "Handle messaging like 'Tell Sarah I'm running late'",
      "Schedule events conversationally",
      "Surface proactive insights like upcoming birthdays or scheduling conflicts",
      "Route memory requests to memory-keeper and briefing requests to daily-intel"
    ]
  },
